# Production Database Configuration EXAMPLE
# 
# Copy this file to .env.production and fill in your actual values
# cp .env.production.example .env.production
#
# This configuration is used when running: npm run seed:admin
# It connects to your Cloud SQL production database via Cloud SQL Proxy

# Database Configuration
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USER=nestjs_user
DATABASE_NAME=subscription_db
DATABASE_PASSWORD=YOUR_PASSWORD_HERE

# To get the production password:
# Method 1 - Using gcloud CLI:
#   gcloud secrets versions access latest --secret=database-password
#
# Method 2 - Using Google Cloud Console:
#   1. Go to https://console.cloud.google.com/security/secret-manager
#   2. Find 'database-password' secret
#   3. View the secret value

# Public API base used to build local upload URLs
API_PUBLIC_BASE_URL=https://subscription-backend-528466251837.us-central1.run.app

# File storage
# Use `gcs` on Cloud Run to store uploaded images in Google Cloud Storage.
FILE_STORAGE_DRIVER=gcs
FILE_STORAGE_LOCAL_DIR=uploads
GCS_BUCKET_NAME=box-subscription-system-images
# Optional CDN/custom bucket domain. Leave blank to use storage.googleapis.com.
GCS_PUBLIC_BASE_URL=

# Firebase Admin SDK (for push notifications)
# For Cloud Run, mount the service account JSON as a secret
# gcloud run services update subscription-backend --update-secrets GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account:latest
# Or set the path to where the secret is mounted:
GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-service-account.json
