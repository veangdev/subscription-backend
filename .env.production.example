# Production Database Configuration EXAMPLE
# 
# Copy this file to .env.production and fill in your actual values
# cp .env.production.example .env.production
#
# This configuration is used when running: npm run seed:admin
# It connects to your Cloud SQL production database via Cloud SQL Proxy

# Database Configuration
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USER=nestjs_user
DATABASE_NAME=subscription_db
DATABASE_PASSWORD=YOUR_PASSWORD_HERE

# To get the production password:
# Method 1 - Using gcloud CLI:
#   gcloud secrets versions access latest --secret=database-password
#
# Method 2 - Using Google Cloud Console:
#   1. Go to https://console.cloud.google.com/security/secret-manager
#   2. Find 'database-password' secret
#   3. View the secret value
